classDiagram
    %% Entities
    [x]class Subject {
        +Long id
        +String name
        +Instant createdAt
    }

    [x]class StudySession {
        +Long id
        +Long subjectId
        +int durationMin
        +String notes
        +Instant timestamp
    }

    %% Repositories
    [x]class SubjectRepository {
    }

    [x]class StudySessionRepository {
        +findById(id)
    }

    %% Services
    [x]class SubjectService {
        +getAllSubjects()
        +createSubject(subject)
        +deleteSubject(id)
    }

    [x]class StudySessionService {
        +getAllSessions()
        +createSession(session)
        +updateSession(id, session)
        +deleteSession(id)
    }

    %% Controllers
    []class SubjectController {
        +GET /subjects
        +POST /subjects
        +DELETE /subjects/{id}
    }

    []class StudySessionController {
        +GET /sessions
        +POST /sessions
        +PUT /sessions/{id}
        +DELETE /sessions/{id}
    }

    %% DTOs
    []class SubjectDTO {
        +Long id
        +String name
        +Instant createdAt
    }

    []class StudySessionDTO {
        +Long id
        +Long subjectId
        +int durationMin
        +String notes
        +Instant timestamp
    }

    %% Exceptions
    []class ResourceNotFoundException
    []class InvalidRequestException
    []class GlobalExceptionHandler

    %% Relationships
    SubjectRepository ..> Subject : manages
    StudySessionRepository ..> StudySession : manages

    SubjectService --> SubjectRepository : uses
    StudySessionService --> StudySessionRepository : uses

    SubjectController --> SubjectService : uses
    StudySessionController --> StudySessionService : uses

    SubjectController --> SubjectDTO : returns
    StudySessionController --> StudySessionDTO : returns

    GlobalExceptionHandler --> ResourceNotFoundException : handles
    GlobalExceptionHandler --> InvalidRequestException : handles
